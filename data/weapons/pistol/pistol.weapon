# M1911 — starting sidearm.
# Semi-auto: requires trigger release between shots.

id              PISTOL
name            M1911
packed_name     Mustang
category        PRIMARY
fire_mode       SEMI

damage          40
mag_size        8
reserve_max     80
fire_cooldown   0.18
reload_time     1.3
pellets         1
spread_deg      0.0

buy_price       0
ammo_price      100
tint            255 220 140 255

bullet_speed    320.0
bullet_life     0.35
tracer_width    0.025

recoil_pitch    0.55
recoil_yaw      0.18

# Linear damage falloff from 15m (1.00x) to 35m (0.55x).
dropoff         15.0  35.0  0.55

model           pistol.obj
model_scale     35.0
model_yaw       28.0
model_offset    0.05 0.09 0.0

# Fire SFX: bank (SHOT|SHOTGUN|RAYGUN), volume, pitch.
sfx             SHOT 0.55 1.10
# Haptic punch on fire: shake amount, shake time, rumble low, rumble high.
haptic          0.10 0.30 0.25 0.06
# Mystery Box roll weight (1.0 = baseline, 0 = never).
mbox_weight     1.0

# Arms-viewmodel grip (hand.R bone seating). pos is bone-local metres after
# the base +90X rotation: +x right, +y toward muzzle, +z up. Tune via
# --screenshot-viewmodels.
vm_grip_pos     0 0 -0.05
vm_grip_rot     0 0 0
vm_grip_scale   1.0
